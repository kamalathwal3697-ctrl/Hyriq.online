{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hyriq.onrender.com/api/:path*"
    },
    {
      "source": "/hyriq.apk",
      "destination": "https://hyriq.onrender.com/hyriq.apk"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
